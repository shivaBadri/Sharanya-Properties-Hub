# ─── Sharanya Properties — environment variables ───────────────────────────

# PostgreSQL — set this to turn on database-backed lead capture.
# Works with Vercel Postgres, Neon, Supabase, Railway, or self-hosted.
# (Vercel Postgres also exposes POSTGRES_URL, which the app reads too.)
# Use your provider's POOLED connection string on serverless.
# Leave BLANK for local dev to fall back to a JSON file (no DB needed).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sharanya?sslmode=require"

# ─── Lead notifications (all optional; configure any subset) ────────────────
# Email alert to sales via Resend (https://resend.com):
RESEND_API_KEY=""
NOTIFY_EMAIL="sales@sharanyaproperties.in"
NOTIFY_FROM="leads@sharanyaproperties.in"   # must be a Resend-verified sender
# Fire the lead JSON at any endpoint (e.g. a Zapier/Make/n8n flow that
# forwards to WhatsApp):
LEAD_WEBHOOK_URL=""

# ─── Public site URL (canonical URLs, sitemap, OG tags) ────────────────────
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ─── Admin authentication (NextAuth — Module 3) ────────────────────────────
# Required to sign in to /admin. Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET=""
# Your site's URL. Local: http://localhost:3000 . Production: your real https URL.
NEXTAUTH_URL="http://localhost:3000"
# Seed an admin user (after running db/schema.sql):
#   node scripts/create-admin.mjs admin@yourco.com 'a-strong-password' "Admin" SUPER_ADMIN

# ─── Image uploads — Cloudinary (Gallery / Media, Module 7) ─────────────────
# Enables the Upload button in the admin gallery. Without it you can still add
# images by URL / /public path. Format below (copy from your Cloudinary dashboard):
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
